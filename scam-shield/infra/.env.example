# Copy to .env and adjust. Unset DATABASE_URL/REDIS_URL to use in-memory mode.
SCAMSHIELD_JWT_SECRET=change-me-in-production
SCAMSHIELD_JWT_EXPIRES=3600
DATABASE_URL=postgresql+asyncpg://scamshield:scamshield@localhost:5432/scamshield
REDIS_URL=redis://localhost:6379/0
SCAMSHIELD_LLM_PROVIDER=deterministic-stub
SCAMSHIELD_CORS_ORIGINS=http://localhost:5173
# Only needed if you switch the LLM provider away from the stub:
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
